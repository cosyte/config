{
  "name": "@cosyte/test-utils",
  "version": "0.0.1",
  "description": "Framework-agnostic conformance test kit for the @cosyte/* parsers — generic round-trip, lenient-mode, immutability, warning-code, and PHI-leak invariant runners.",
  "keywords": [
    "testing",
    "conformance",
    "property-testing",
    "fast-check",
    "phi",
    "healthcare",
    "cosyte"
  ],
  "homepage": "https://github.com/cosyte/config/tree/main/packages/test-utils#readme",
  "bugs": {
    "url": "https://github.com/cosyte/config/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cosyte/config.git",
    "directory": "packages/test-utils"
  },
  "license": "MIT",
  "author": "Cosyte <hello@cosyte.com> (https://cosyte.com)",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.0.0",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "prettier": "@cosyte/prettier-config",
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\" --max-warnings=0",
    "lint:fix": "eslint \"src/**/*.ts\" \"test/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.{ts,md}\" \"test/**/*.ts\" \"*.{json,md,yml}\"",
    "format:check": "prettier --check \"src/**/*.{ts,md}\" \"test/**/*.ts\" \"*.{json,md,yml}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "attw": "attw --pack .",
    "clean": "rm -rf dist coverage",
    "prepublishOnly": "pnpm clean && pnpm typecheck && pnpm lint && pnpm test && pnpm build && pnpm attw"
  },
  "peerDependencies": {
    "fast-check": "^3.0.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.5",
    "@cosyte/eslint-config": "workspace:^",
    "@cosyte/prettier-config": "workspace:^",
    "@cosyte/tsconfig": "workspace:^",
    "@cosyte/tsup-config": "workspace:^",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.7.0",
    "fast-check": "4.9.0",
    "prettier": "3.9.6",
    "tsup": "8.5.1",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
