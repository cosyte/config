{
  "name": "@cosyte/vitest-config",
  "version": "0.0.1",
  "description": "Shared Vitest config (v8 coverage, per-directory >=90 gates) for @cosyte/* packages.",
  "keywords": [
    "vitest",
    "coverage",
    "test",
    "doctest",
    "documentation",
    "cosyte"
  ],
  "homepage": "https://github.com/cosyte/config/tree/main/packages/vitest-config#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cosyte/config.git",
    "directory": "packages/vitest-config"
  },
  "license": "MIT",
  "author": "Cosyte <hello@cosyte.com> (https://cosyte.com)",
  "type": "module",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./snippets": {
      "types": "./snippets.d.ts",
      "default": "./snippets.js"
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "snippets.js",
    "snippets.d.ts",
    "README.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@vitest/coverage-v8": "^4.0.0",
    "vite": "^6.0.0 || ^7.0.0 || ^8.0.0",
    "vitest": "^4.0.0"
  }
}
